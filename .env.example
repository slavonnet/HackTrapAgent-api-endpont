HTTP_ADDR=:8080
REQUEST_BODY_LIMIT_BYTES=1048576

CLICKHOUSE_ADDRS=localhost:9000
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_TABLE=access_events
CLICKHOUSE_SECURE=false
CLICKHOUSE_DIAL_TIMEOUT_SECONDS=5
CLICKHOUSE_MAX_OPEN_CONNS=10
CLICKHOUSE_MAX_IDLE_CONNS=10
CLICKHOUSE_CONN_MAX_LIFETIME_SECONDS=300

# Optional:
# LIMITS=[{"keys":["source","mashine_id"],"window":60,"limit":100}]
# WHITELIST=[{"source":"10.0.0.1"}]
# BLACKLIST=[{"source":"192.168.1.10"}]
